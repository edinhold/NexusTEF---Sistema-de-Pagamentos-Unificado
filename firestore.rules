rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - displayName: string (optional) - User display name
    //   - role: string (required, enum: ['admin', 'user']) - User role
    //   - createdAt: timestamp (optional) - Account creation timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'MASTER' ||
          (request.auth.token.email == "edinhold@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'email', 'role']) &&
             data.id is string && data.id.size() > 0 &&
             data.email is string &&
             data.role in ['MASTER', 'ADMIN', 'OPERATOR'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile. Admins can read all profiles.
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile if it's not an admin role (unless they are already admin or the default admin)
      // Admins can create any user profile.
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) || isAdmin());
      
      // Users can update their own profile, but cannot change their role unless they are an admin.
      // Admins can update any user profile.
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) || isAdmin()) &&
                    (isOwner(userId) ? (request.resource.data.role == resource.data.role || isAdmin()) : true);
      
      // Only admins can delete users.
      allow delete: if isAdmin();
    }
  }
}
